rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActiveUser() {
      return isAuthenticated()
        && userDoc().exists
        && userDoc().data.active == true;
    }

    function isAdmin() {
      return isActiveUser()
        && userDoc().data.role == 'admin';
    }

    // ─── Usuários (só controle de login) ────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ─── Dados do sistema — liberado para quem está logado ──────
    match /clients/{clientId} {
      allow read, write: if isAuthenticated();
    }

    match /contracts/{contractId} {
      allow read, write: if isAuthenticated();

      match /items/{itemId} {
        allow read, write: if isAuthenticated();
      }

      match /installments/{installmentId} {
        allow read, write: if isAuthenticated();

        match /payments/{paymentId} {
          allow read, write: if isAuthenticated();
        }
      }
    }

    match /auditLogs/{logId} {
      allow read, create: if isAuthenticated();
    }

    match /settings/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /notes/{noteId} {
      allow read, write: if isAuthenticated();
    }

    match /links/{linkId} {
      allow read, write: if isAuthenticated();
    }

    // Pagamentos — consulta em qualquer contrato
    match /{path=**}/payments/{paymentId} {
      allow read, write: if isAuthenticated();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

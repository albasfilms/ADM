rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActiveUser() {
      return isAuthenticated()
        && userDoc().exists
        && userDoc().data.active == true;
    }

    function isAdmin() {
      return isActiveUser() && userDoc().data.role == 'admin';
    }

    function isCollaborator() {
      return isActiveUser() && userDoc().data.role == 'collaborator';
    }

    function hasStaffAccess() {
      return isAdmin() || isCollaborator();
    }

    function validUserRole(role) {
      return role in ['admin', 'collaborator'];
    }

    function validTimestamp(field) {
      return field is timestamp;
    }

    // ─── Usuários ───────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isActiveUser() && request.auth.uid == userId;
      allow read: if isAdmin();

      allow create: if isAdmin()
        && validUserRole(request.resource.data.role)
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.active is bool
        && validTimestamp(request.resource.data.createdAt)
        && validTimestamp(request.resource.data.updatedAt);

      allow update: if isAdmin()
        && validUserRole(request.resource.data.role)
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.active is bool
        && validTimestamp(request.resource.data.updatedAt)
        && request.resource.data.role == resource.data.role || isAdmin();

      allow delete: if isAdmin();
    }

    function validClientData() {
      return request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.nameLower is string
        && request.resource.data.personType in ['individual', 'company']
        && request.resource.data.status in ['active', 'inactive']
        && request.resource.data.document is string
        && request.resource.data.phone is string
        && request.resource.data.whatsapp is string
        && request.resource.data.email is string
        && request.resource.data.instagram is string
        && request.resource.data.address is string
        && request.resource.data.city is string
        && request.resource.data.state is string
        && request.resource.data.notes is string
        && validTimestamp(request.resource.data.updatedAt);
    }

    // ─── Clientes (Etapa 2) ─────────────────────────────────────
    match /clients/{clientId} {
      allow read: if hasStaffAccess();
      allow create: if hasStaffAccess()
        && validClientData()
        && validTimestamp(request.resource.data.createdAt);
      allow update: if hasStaffAccess() && validClientData();
      allow delete: if isAdmin();
    }

    function validContractData() {
      return request.resource.data.clientId is string
        && request.resource.data.clientName is string
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.status in [
          'budget', 'awaiting_signature', 'awaiting_entry', 'confirmed',
          'in_progress', 'finished', 'paid_off', 'cancelled'
        ]
        && request.resource.data.totalAmount is int
        && request.resource.data.totalAmount >= 0
        && request.resource.data.receivedAmount is int
        && request.resource.data.receivedAmount >= 0
        && request.resource.data.pendingAmount is int
        && request.resource.data.pendingAmount >= 0
        && request.resource.data.overdueAmount is int
        && request.resource.data.overdueAmount >= 0
        && validTimestamp(request.resource.data.updatedAt);
    }

    function validContractItem() {
      return request.resource.data.description is string
        && request.resource.data.serviceType is string
        && request.resource.data.amount is int
        && request.resource.data.amount >= 0;
    }

    function validInstallment() {
      return request.resource.data.number is int
        && request.resource.data.description is string
        && request.resource.data.expectedAmount is int
        && request.resource.data.expectedAmount >= 0
        && request.resource.data.paidAmount is int
        && request.resource.data.paidAmount >= 0
        && request.resource.data.status in ['pending', 'paid', 'partial', 'overdue', 'cancelled']
        && validTimestamp(request.resource.data.dueDate);
    }

    // ─── Contratos (Etapas 3–4) ─────────────────────────────────
    match /contracts/{contractId} {
      allow read: if hasStaffAccess();
      allow create: if hasStaffAccess()
        && validContractData()
        && validTimestamp(request.resource.data.createdAt);
      allow update: if hasStaffAccess() && validContractData();
      allow delete: if isAdmin();

      match /items/{itemId} {
        allow read: if hasStaffAccess();
        allow create, update: if hasStaffAccess() && validContractItem();
        allow delete: if isAdmin();
      }

      match /installments/{installmentId} {
        allow read: if hasStaffAccess();
        allow create: if hasStaffAccess() && validInstallment();
        allow update: if hasStaffAccess() && validInstallment();
        allow delete: if isAdmin();

        match /payments/{paymentId} {
          allow read: if hasStaffAccess();
          allow create: if hasStaffAccess()
            && request.resource.data.amount is int
            && request.resource.data.amount > 0
            && request.resource.data.paymentMethod is string
            && request.resource.data.contractId is string
            && request.resource.data.clientId is string
            && validTimestamp(request.resource.data.paymentDate)
            && validTimestamp(request.resource.data.createdAt);
          allow update: if isAdmin();
          allow delete: if isAdmin();
        }
      }
    }

    // ─── Auditoria ──────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isActiveUser();
      allow update, delete: if false;
    }

    // ─── Configurações ──────────────────────────────────────────
    match /settings/{docId} {
      allow read: if hasStaffAccess();
      allow write: if isAdmin();
    }

    // Bloqueia tudo que não foi explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
